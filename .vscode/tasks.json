{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build mini-drone for debug",
            "detail": "Debug build",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/mini-drone/cross"
            },
            "command": "cargo",
            "args": [
                "build",
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build mini-drone",
            "detail": "Release build",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/mini-drone/cross"
            },
            "command": "cargo",
            "args": [
                "build",
                "--release",
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Flash mini-drone",
            "detail": "Flashing firmware on flight controller unit",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/mini-drone"
            },
            "command": "cargo",
            "args": [
                "xtask",
                "flash",
            ],
        },
        {
            "label": "Test mini-drone on host",
            "detail": "Testing firmware on host machine",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/mini-drone"
            },
            "command": "cargo",
            "args": [
                "xtask",
                "test",
                "host",
            ],
        },
        {
            "label": "Test mini-drone on target",
            "detail": "Testing firmware on flight controller unit (self-tests)",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/mini-drone"
            },
            "command": "cargo",
            "args": [
                "xtask",
                "test",
                "target",
            ],
        }
    ]
}